# Copy to .env.local for `vercel dev`, and set these in the Vercel dashboard
# (Project → Settings → Environment Variables) for the deployed app.

# Neon Postgres connection string (Neon dashboard → Connection Details →
# "Pooled connection"). Required for cloud sync; without it the app stays
# fully local.
DATABASE_URL=postgres://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# Single shared passphrase ("light auth"). The app sends this back as the
# x-app-token header; only requests with the right value can read/write.
# Leave unset to run the API with no auth (anyone with the URL can access it).
APP_TOKEN=change-me-to-a-long-random-string

# OPTIONAL — Vercel Blob. When set, large images (>~1MB) are offloaded to Blob
# object storage and only their URL is kept in Neon (keeps the DB small/fast).
# Without it, images are stored inline in Postgres. Get it from the Vercel
# dashboard: Storage → create a Blob store → it injects this automatically.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxx
